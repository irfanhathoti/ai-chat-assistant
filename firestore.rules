rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // A user can only read/write documents under their own /users/{uid} tree.
    match /users/{userId} {

      // Chats belong to the owning user.
      match /chats/{chatId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;

        // Messages live under each chat and inherit the same ownership rule.
        match /messages/{messageId} {
          allow read, write: if request.auth != null
                             && request.auth.uid == userId;
        }
      }
    }
  }
}
